# Configuración de Servidor
SERVER_PORT=8080

# Base de Datos PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/CALLAO?currentSchema=callao
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=tu_contraseña

# JWT Secret (Genera una cadena alfanumérica de al menos 64 caracteres)
APP_JWT_SECRET=8f7e2d9a4b6c1d3e5f7a9b0c2d4e6f8a1b3c5d7e9f1a2b4c6d8e0f2a4b6c8d0e

# CORS Origins Permitidos (separados por coma)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,https://callao-ame9.vercel.app

# Gmail API Credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=
